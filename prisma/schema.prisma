// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String @id @default(cuid())

  name        String
  avatarUrl   String?

  email       String @unique
  password    String

  personas    Persona[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Persona {
  id                     String   @id @default(cuid())

  userId                 String
  user                   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  name                   String
  email                  String?

  igHandle               String? @unique
  avatarUrl              String?

  socialMetricRecords   SocialMetricRecord[]

  decisions              Decision[]
  inspirations           Inspiration[]
  feedbacks              Feedback[]

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([userId])
}

model SocialMetricRecord {
  id          String   @id @default(cuid())

  metrics     Json

  personaId      String
  persona        Persona @relation(fields: [personaId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([personaId])
}

model Decision {
  id             String   @id @default(cuid())

  personaId      String
  persona        Persona @relation(fields: [personaId], references: [id], onDelete: Cascade)

  title          String
  description    String?

  status         DecisionStatus @default(ACTIVE)

  thumbnailUrl   String?

  inspirations   Inspiration[]
  feedbacks      Feedback[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([personaId])
}

model Inspiration {
  id             String   @id @default(cuid())

  personaId      String
  persona        Persona @relation(fields: [personaId], references: [id], onDelete: Cascade)

  title          String
  description    String?

  sourceUrl      String?
  thumbnailUrl   String?

  decisions      Decision[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  @@index([personaId])
}

model Feedback {
  id                    String   @id @default(cuid())
  
  personaId      String
  persona        Persona @relation(fields: [personaId], references: [id], onDelete: Cascade)

  title                 String
  description           String?

  contentThumbnailUrl   String?
  contentSourceUrl      String?

  decisions             Decision[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([personaId])
}

enum DecisionStatus {
  ACTIVE
  IN_PROGRESS
  PAUSED
  COMPLETED
  CANCELLED
}